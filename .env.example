# ── RPC ──────────────────────────────────────────────────────────────────────
# Public endpoints verified working; swap for Infura/Alchemy for production polish.
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com

# ── Deployer / script wallet ─────────────────────────────────────────────────
# TESTNET-ONLY key. Never a real-funds key. Hardhat and scripts/gate0.ts read
# this from the repo-root .env.
PRIVATE_KEY=

# ── Zama relayer (testnet v2 — migrated from relayer.testnet.zama.cloud) ─────
# The @zama-fhe/sdk chain presets embed the correct relayer URL; this env var
# is an OVERRIDE only. Gateway chain id is 10901 (v2). The /v2 PATH SUFFIX is
# required — the bare origin is not equivalent (see docs/SDK-VERIFICATION.md).
NEXT_PUBLIC_ZAMA_RELAYER_URL=https://relayer.testnet.zama.org/v2
NEXT_PUBLIC_CHAIN_ID=11155111

# ── Optional ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_WALLETCONNECT_ID=
ETHERSCAN_API_KEY=
